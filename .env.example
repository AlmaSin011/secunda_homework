# --- Application --------------------------------------------------------
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# --- MySQL --------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=taskmgr
MYSQL_USER=taskmgr
MYSQL_PASSWORD=taskpass
MYSQL_PORT=3306

MYSQL_DSN=mysql://taskmgr:taskpass@tcp(mysql:3306)/taskmgr?parseTime=true&multiStatements=true

# --- Redis --------------------------------------------------------------
REDIS_PORT=6379
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ----------------------------------------------------------------
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
# TTL в формате Go time.Duration: "15m", "1h", "24h".
JWT_TTL=24h

# --- Rate limit ---------------------------------------------------------
# 100 req/min на пользователя = ~1.67 RPS. Burst — пиковое допустимое число запросов.
RATE_LIMIT_RPS=1.67
RATE_LIMIT_BURST=100

# --- Metrics ------------------------------------------------------------
METRICS_PATH=/metrics
